---
import Base from '@/layouts/Base.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allCompanies = await getCollection('companies');
const relatedCompany = entry.data.company
  ? allCompanies.find((c) => c.id === entry.data.company)
  : null;

const isCaseStudy = !!(entry.data.challenge || entry.data.results);

const creativeWorkJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: entry.data.name,
  description: entry.data.description,
  author: {
    '@type': 'Person',
    name: 'Blazej Mrozinski',
    url: 'https://www.blazejmrozinski.com/about',
  },
};
---

<Base title={entry.data.metaTitle || entry.data.name} description={entry.data.description}>
  <JsonLd data={creativeWorkJsonLd} />

  <div class="container max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <a href="/projects" class="text-sm text-muted-foreground hover:text-foreground transition-colors">&larr; Case Studies</a>

    <div class="mt-6 mb-8" data-animate>
      <h1 class="text-4xl font-bold tracking-tight">{entry.data.name}</h1>
      <div class="flex items-center gap-3 mt-3 flex-wrap">
        <span class="text-xs bg-secondary text-secondary-foreground px-2.5 py-1 rounded-full">{entry.data.domain}</span>
        {isCaseStudy && (
          <span class="text-xs bg-primary text-primary-foreground px-2.5 py-1 rounded-full">Case Study</span>
        )}
        {relatedCompany && (
          <a href={`/work/${relatedCompany.id}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            {relatedCompany.data.name}
          </a>
        )}
      </div>
    </div>

    {/* Case study structured sections */}
    {isCaseStudy && (
      <div class="mb-10 space-y-8" data-animate>
        {entry.data.challenge && (
          <div class="rounded-lg border bg-card p-6">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">The Challenge</h2>
            <p class="text-foreground leading-relaxed">{entry.data.challenge}</p>
          </div>
        )}

        {entry.data.approach && (
          <div class="rounded-lg border bg-card p-6">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">The Approach</h2>
            <p class="text-foreground leading-relaxed">{entry.data.approach}</p>
          </div>
        )}

        {entry.data.results && entry.data.results.length > 0 && (
          <div class="rounded-lg border bg-card p-6">
            <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">Results</h2>
            <ul class="space-y-2">
              {entry.data.results.map((result) => (
                <li class="flex items-start gap-3">
                  <svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                  </svg>
                  <span class="text-foreground">{result}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {entry.data.tools && entry.data.tools.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {entry.data.tools.map((tool) => (
              <span class="text-xs bg-muted text-muted-foreground px-2.5 py-1 rounded-full">{tool}</span>
            ))}
          </div>
        )}
      </div>
    )}

    {/* Body content (narrative, additional detail) */}
    <div class="prose prose-neutral dark:prose-invert max-w-none" data-animate>
      <Content />
    </div>
  </div>
</Base>

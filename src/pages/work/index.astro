---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CompanyCard from '../../components/CompanyCard.astro';
import { getCollection, render } from 'astro:content';

const workPage = (await getCollection('pages')).find((p) => p.id === 'work');
let WorkContent: any = null;
if (workPage) {
  const rendered = await render(workPage);
  WorkContent = rendered.Content;
}

const companies = (await getCollection('companies'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="Work" description="What Blazej Mrozinski does — product development, psychometric assessment design, AI workflow consulting, and growth engineering.">
  <Header />

  <main class="max-w-3xl mx-auto px-6 py-8">
    <h1 class="font-serif text-3xl font-bold mb-6">Work</h1>

    {WorkContent && (
      <div class="prose prose-stone prose-lg font-serif mb-10">
        <WorkContent />
      </div>
    )}

    <section>
      <h2 class="text-xs font-semibold text-warm-400 uppercase tracking-wider mb-4">Companies</h2>
      {companies.map((company) => (
        <CompanyCard
          name={company.data.name}
          domain={company.data.domain}
          role={company.data.role}
          slug={company.id}
        />
      ))}
    </section>
  </main>

  <Footer />
</Base>

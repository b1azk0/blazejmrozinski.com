---
import Base from "./Base.astro";
import JsonLd from "@/components/JsonLd.astro";
import Breadcrumb from '@/components/Breadcrumb.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';
import SeriesNav from '@/components/SeriesNav.astro';
import RelatedPosts from '@/components/RelatedPosts.astro';
import { labels, type LabelSlug } from '@/lib/labels';
import { PERSON_ID, SITE_URL } from '@/lib/jsonld';
import { getTopic } from '@/lib/topics';
import { loadSeries, getSeriesPosts } from '@/lib/series';
import { pickRelated } from '@/lib/related-posts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  lastmod?: Date;
  tags: string[];
  audience: string[];
  author?: string;
  label?: string;
  topics?: string[];
  series?: string;
  seriesIndex?: number;
  allPosts: CollectionEntry<'blog'>[];
  crumbs: { label: string; href?: string }[];
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, lastmod, tags, audience, author, label, topics = [], series, seriesIndex, allPosts, crumbs, headings } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const slug = Astro.params.slug;
const canonicalUrl = `https://www.blazejmrozinski.com/blog/${slug}/`;
const coverUrl = label ? `/covers/${slug}.png` : undefined;
const labelConfig = label && label in labels ? labels[label as LabelSlug] : null;

const showSidebar = headings.filter((h) => h.depth === 2).length >= 3;

const dateModified = (lastmod ?? date).toISOString();
const authorIsBlazej = !author || author === 'Blazej Mrozinski';
const authorNode = authorIsBlazej
  ? { '@id': PERSON_ID }
  : { '@type': 'Person', name: author };

const topicEntries = topics.map((slug) => ({ slug, config: getTopic(slug) })).filter((t) => t.config);

let seriesParts: CollectionEntry<'blog'>[] = [];
let seriesTitle: string | undefined;
if (series) {
  seriesParts = getSeriesPosts(series, allPosts);
  seriesTitle = loadSeries().get(series)?.title;
}

let relatedPosts: CollectionEntry<'blog'>[] = [];
if (!series) {
  const currentSlug = Astro.params.slug!;
  const current = allPosts.find((p) => p.id === currentSlug);
  if (current) {
    relatedPosts = pickRelated(current, allPosts, 4);
  }
}

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  author: authorNode,
  publisher: { '@id': PERSON_ID },
  keywords: tags.join(', '),
  ...(coverUrl ? { image: `${SITE_URL}${coverUrl}` } : {}),
  ...(topicEntries.length > 0
    ? {
        about: topicEntries.map((t) => ({
          '@type': 'Thing',
          name: t.config!.title,
          url: `${SITE_URL}/blog/topic/${t.slug}/`,
        })),
      }
    : {}),
  ...(series && seriesTitle
    ? {
        isPartOf: {
          '@type': 'CreativeWorkSeries',
          url: `${SITE_URL}/blog/series/${series}/`,
          name: seriesTitle,
        },
      }
    : {}),
};
---

<Base title={title} description={description} ogType="article" ogImage={coverUrl} author={author} keywords={tags.length > 0 ? tags.join(', ') : undefined}>
  <JsonLd data={articleJsonLd} />

  <div class:list={["container mx-auto px-4 sm:px-6 py-12", showSidebar ? "max-w-5xl" : "max-w-3xl"]}>
    <Breadcrumb crumbs={crumbs} />
    <div class:list={[showSidebar && "md:flex md:gap-8"]}>
      {showSidebar && <BlogSidebar headings={headings} />}
      <article class="max-w-3xl min-w-0">
        <header class="mb-8">
          <h1 class="text-4xl font-bold tracking-tight mb-4">{title}</h1>
          <div class="flex items-center gap-4 text-muted-foreground text-sm flex-wrap">
            <a href="/about" class="hover:text-foreground transition-colors">Blazej Mrozinski</a>
            <span>&middot;</span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {labelConfig && label && (
              <>
                <span>&middot;</span>
                <a href={`/blog?label=${label}`} class="inline-flex items-center gap-1.5 hover:text-foreground transition-colors">
                  <span
                    class="w-1.5 h-1.5 rounded-full"
                    style={`background-color: ${labelConfig.accent};`}
                    aria-hidden="true"
                  />
                  {labelConfig.name}
                </a>
              </>
            )}
          </div>
          {topicEntries.length > 0 && (
            <p class="text-sm text-muted-foreground mt-3">
              <span>Filed under: </span>
              {topicEntries.map((t, i) => (
                <>
                  <a href={`/blog/topic/${t.slug}/`} class="hover:text-foreground transition-colors">{t.config!.title}</a>
                  {i < topicEntries.length - 1 && <span> · </span>}
                </>
              ))}
            </p>
          )}
        </header>

        {coverUrl && (
          <div class="mb-10 -mx-4 sm:mx-0">
            <img
              src={coverUrl}
              alt={title}
              class="w-full rounded-none sm:rounded-lg"
              loading="eager"
              width="1200"
              height="630"
            />
          </div>
        )}

        {series && seriesTitle && (
          <SeriesNav
            currentId={Astro.params.slug!}
            currentIndex={seriesIndex!}
            seriesTitle={seriesTitle}
            seriesSlug={series}
            parts={seriesParts}
            position="header"
          />
        )}

        <div class="prose prose-neutral dark:prose-invert max-w-none">
          <slot />
        </div>

        {series && seriesTitle && (
          <SeriesNav
            currentId={Astro.params.slug!}
            currentIndex={seriesIndex!}
            seriesTitle={seriesTitle}
            seriesSlug={series}
            parts={seriesParts}
            position="footer"
          />
        )}

        {!series && relatedPosts.length > 0 && (
          <RelatedPosts posts={relatedPosts} />
        )}
      </article>
    </div>
  </div>
</Base>

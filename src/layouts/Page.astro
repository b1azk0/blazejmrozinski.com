---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const props = Astro.props;
---

<Base {...props}>
  <Header />
  <main class="max-w-5xl mx-auto px-6 py-8">
    <slot />
  </main>
  <Footer />
</Base>

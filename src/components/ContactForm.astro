---
---
<form name="contact" method="POST" data-netlify="true" class="flex gap-2 items-center max-w-lg">
  <input type="hidden" name="form-name" value="contact" />
  <input
    type="email"
    name="email"
    required
    placeholder="your@email.com"
    class="flex-1 px-3 py-2 text-sm bg-dark-800 border border-dark-700 text-warm-100 rounded placeholder-warm-500 focus:outline-none focus:border-warm-400"
  />
  <button
    type="submit"
    class="bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold px-4 py-2 rounded transition-colors"
  >
    Send
  </button>
</form>

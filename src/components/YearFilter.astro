---
interface Props {
  counts: Record<number, number>;
}

const { counts } = Astro.props;
const totalCount = Object.values(counts).reduce((sum, n) => sum + n, 0);
const years = Object.keys(counts).map(Number).sort((a, b) => b - a);
---

<div class="flex gap-2 flex-wrap mb-8" id="year-filter" data-pagefind-ignore>
  <a
    href="/publications"
    class:list={[
      'text-xs px-3 py-1.5 rounded-full transition-colors font-medium',
      'bg-primary text-primary-foreground',
    ]}
    data-year="all"
  >
    All<span class="opacity-50 ml-0.5">{totalCount}</span>
  </a>
  {years.map((year) => (
    <a
      href={`/publications?year=${year}`}
      class:list={[
        'text-xs px-3 py-1.5 rounded-full transition-colors font-medium',
        'bg-secondary text-secondary-foreground hover:bg-accent',
      ]}
      data-year={String(year)}
    >
      {year}<span class="opacity-50 ml-0.5">{counts[year]}</span>
    </a>
  ))}
</div>

<script>
  function filterPublications() {
    const params = new URLSearchParams(window.location.search);
    const activeYear = params.get('year');
    const filterLinks = document.querySelectorAll<HTMLAnchorElement>('#year-filter a');
    const yearSections = document.querySelectorAll<HTMLElement>('[data-pub-year]');
    const typeSections = document.querySelectorAll<HTMLElement>('[data-pub-type]');

    filterLinks.forEach((link) => {
      const year = link.dataset.year;
      const isActive = (!activeYear && year === 'all') || activeYear === year;
      link.classList.toggle('bg-primary', isActive);
      link.classList.toggle('text-primary-foreground', isActive);
      link.classList.toggle('bg-secondary', !isActive);
      link.classList.toggle('text-secondary-foreground', !isActive);
    });

    yearSections.forEach((section) => {
      if (!activeYear) {
        section.style.display = '';
      } else {
        section.style.display = section.dataset.pubYear === activeYear ? '' : 'none';
      }
    });

    typeSections.forEach((section) => {
      const visible = section.querySelectorAll('[data-pub-year]:not([style*="display: none"])');
      section.style.display = visible.length > 0 ? '' : 'none';
    });
  }

  filterPublications();
  document.addEventListener('astro:after-swap', filterPublications);
</script>

---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Work', href: '/work' },
  { label: 'Projects', href: '/projects' },
  { label: 'Publications', href: '/publications' },
  { label: 'Blog', href: '/blog' },
  { label: 'CV', href: '/cv' },
];

const socialLinks = [
  { label: 'in', href: 'https://linkedin.com/in/blazejmrozinski', title: 'LinkedIn' },
  { label: 'gh', href: 'https://github.com/b1azk0', title: 'GitHub' },
  { label: 'gs', href: 'https://scholar.google.com/citations?user=blazejmrozinski', title: 'Google Scholar' },
];

function isActive(href: string): boolean {
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header class="bg-dark-900 text-warm-100">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-8">
      <a href="/" class="font-sans text-sm font-bold tracking-widest text-white hover:text-warm-300 transition-colors">
        BLAZEJ MROZINSKI
      </a>
      <ul class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-sm transition-colors',
                isActive(link.href)
                  ? 'text-white font-semibold'
                  : 'text-warm-400 hover:text-warm-200',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="flex items-center gap-4 border-l border-dark-700 pl-4">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          title={link.title}
          class="text-sm text-warm-400 hover:text-warm-200 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---
<div class="flex gap-2 flex-wrap mb-6" id="tag-filter">
  <a
    href="/blog/"
    class:list={[
      'text-xs px-3 py-1.5 rounded-full transition-colors font-medium',
      !activeTag
        ? 'bg-primary text-primary-foreground'
        : 'bg-secondary text-secondary-foreground hover:bg-accent',
    ]}
    data-tag="all"
  >
    All
  </a>
  {tags.map((tag) => (
    <a
      href={`/blog?tag=${encodeURIComponent(tag)}`}
      class:list={[
        'text-xs px-3 py-1.5 rounded-full transition-colors font-medium',
        activeTag === tag
          ? 'bg-primary text-primary-foreground'
          : 'bg-secondary text-secondary-foreground hover:bg-accent',
      ]}
      data-tag={tag}
    >
      {tag}
    </a>
  ))}
</div>

<script>
  function filterByTag() {
    const params = new URLSearchParams(window.location.search);
    const activeTag = params.get('tag');
    const articles = document.querySelectorAll<HTMLElement>('[data-tags]');
    const filterLinks = document.querySelectorAll<HTMLAnchorElement>('#tag-filter a');

    filterLinks.forEach((link) => {
      const tag = link.dataset.tag;
      const isActive = (!activeTag && tag === 'all') || activeTag === tag;
      link.classList.toggle('bg-primary', isActive);
      link.classList.toggle('text-primary-foreground', isActive);
      link.classList.toggle('bg-secondary', !isActive);
      link.classList.toggle('text-secondary-foreground', !isActive);
    });

    articles.forEach((article) => {
      if (!activeTag) {
        article.style.display = '';
        return;
      }
      const tags = (article.dataset.tags || '').split(',');
      article.style.display = tags.includes(activeTag) ? '' : 'none';
    });
  }

  filterByTag();
  document.addEventListener('astro:after-swap', filterByTag);
</script>
